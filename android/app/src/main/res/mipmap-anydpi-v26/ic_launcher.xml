<!--
    Adaptive icon structure:
    - background: the maskable icon fills the full 108dp canvas edge-to-edge
      (dark #221F1A background with centered logo artwork).  Using the maskable
      directly — without any white inset layer — avoids the white-ring artifact
      where the background color bleeds through at the shape boundary.
    - foreground: transparent (the logo is embedded in the maskable background).
    - monochrome: wrapped in ic_monochrome_padded to add 12dp inset and keep the
      silhouette within the 72dp safe zone on circle-mask launchers.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <background android:drawable="@mipmap/ic_maskable" />
    <foreground android:drawable="@android:color/transparent" />
    <monochrome android:drawable="@drawable/ic_monochrome_padded" />
</adaptive-icon>
