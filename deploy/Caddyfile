news.lihor.ro {
	# Authentication is enforced by the app. Keycloak is mounted under the same
	# hostname so OAuth redirect URIs do not require a separate DNS record.
	handle /keycloak* {
		reverse_proxy 127.0.0.1:8081
	}

	# Proxy to the Kubernetes NodePort instead of a mutable ClusterIP.
	# Deploy with: helm upgrade news-dashboard ./helm/news-dashboard \
	#   --set service.type=NodePort,service.nodePort=30088
	# The NodePort (30088) is stable across pod restarts and Helm upgrades
	# as long as the value stays the same. Never hardcode a ClusterIP here.
	reverse_proxy 127.0.0.1:30088

	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
}
